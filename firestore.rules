rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // كل مستخدم يقرأ بياناته، والـ users قابلة للقراءة لأي مسجل دخول
    function isAdmin() {
      return request.auth != null
        && request.auth.uid in ['KyOf1zfyclMPwdg5KGBHf1Kpt952'];
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && (request.auth.uid == userId || isAdmin());
      // كتابة:
      // - المستخدم نفسه (كتابة كاملة)
      // - تعديل قائمة الأصدقاء فقط من قبل لاعب آخر
      // - الأدمن يقدر يعدّل أي حقل لأي لاعب (للهدايا والصيانة)
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) ||
        isAdmin()
      );
    }

    // لوحة المتصدرين — قراءة للجميع، كتابة لصاحبها فقط
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // طلبات الصداقة
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow read: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update: if request.auth != null && resource.data.to == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // الإعلانات العامة — الكل يقرأ، الأدمن يكتب
    match /announcements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // جدار البروفايل — تعليقات الزوار
    // أي مسجل دخول يقرأ ويكتب، الكاتب أو صاحب الجدار أو الأدمن يحذف
    match /walls/{ownerUid}/posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
                    && request.resource.data.authorUid == request.auth.uid;
      allow delete: if request.auth != null && (
        resource.data.authorUid == request.auth.uid ||
        request.auth.uid == ownerUid ||
        isAdmin()
      );
    }

    // المنتدى — الأدمن يقدر يحذف أي شي
    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth != null && (resource.data.authorUid == request.auth.uid || isAdmin());
      }

      match /likes/{likeId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == likeId;
      }
    }

    // الإشعارات — كل مستخدم له صندوق إشعارات خاص
    // أي مستخدم يقدر يكتب إشعار لأي مستخدم آخر (طلب صداقة، لايك، تعليق، رسالة…)
    // فقط صاحب الصندوق يقرأ/يعدّل/يحذف
    match /notifications/{ownerUid}/items/{notifId} {
      allow read: if request.auth != null && request.auth.uid == ownerUid;
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      allow update, delete: if request.auth != null && request.auth.uid == ownerUid;
    }

    // إشعارات عامة (بثّ الأدمن) — الكل يقرأ، الأدمن يكتب
    match /globalNotifications/{notifId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // المحادثات — فقط بين المشاركين
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');

      match /messages/{msgId} {
        allow read: if request.auth != null && request.auth.uid in chatId.split('_');
        allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      }
    }
  }
}
