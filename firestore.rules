rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // كل مستخدم يقرأ بياناته، والـ users قابلة للقراءة لأي مسجل دخول
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      // كتابة كاملة للمستخدم نفسه،
      // أو تعديل قائمة الأصدقاء فقط من قبل لاعب آخر،
      // أو الأدمن يقدر يعدّل pendingGifts وpendingGiftsUpdatedAt فقط لأي لاعب
      allow update: if request.auth != null && (
        request.auth.uid == userId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['friends']) ||
        (request.auth.uid == 'KyOf1zfyclMPwdg5KGBHf1Kpt952'
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['pendingGifts', 'pendingGiftsUpdatedAt']))
      );
    }

    // لوحة المتصدرين — قراءة للجميع، كتابة لصاحبها فقط
    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // طلبات الصداقة
    match /friendRequests/{requestId} {
      allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      allow read: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
      allow update: if request.auth != null && resource.data.to == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    // المنتدى
    match /forumPosts/{postId} {
      allow read: if true;
      allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.authorUid == request.auth.uid;

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if request.auth != null && resource.data.authorUid == request.auth.uid;
      }

      match /likes/{likeId} {
        allow read: if true;
        allow create, delete: if request.auth != null && request.auth.uid == likeId;
      }
    }

    // المحادثات — فقط بين المشاركين
    match /chats/{chatId} {
      allow read, write: if request.auth != null && request.auth.uid in chatId.split('_');

      match /messages/{msgId} {
        allow read: if request.auth != null && request.auth.uid in chatId.split('_');
        allow create: if request.auth != null && request.resource.data.from == request.auth.uid;
      }
    }
  }
}
